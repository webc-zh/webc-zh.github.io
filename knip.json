{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "ai/**.js",
    "ai/test/**/*.js",
    "com.js",
    "page/entry/*.{js,svelte}",
    "sh/demo.js",
    "sh/dist/*.js",
    "sh/hook/*.js",
    "vite/com/dev.js",
    "vite/dist/*.js",
    "vite/pug/*.js",
    "gitPage.js"
  ],
  "project": ["**/*.{js,svelte}"],
  "paths": {
    "x/*": ["./x/*"]
  },
  "ignore": ["cli/**", "x/**", ".cache/**", "com/*/demo/**", "oxlint.config.js", "sh/example/**"],
  "ignoreBinaries": ["sh/hook/svg.js", "sh/hook/svelte.js", "sh/hook/styl.js", "sh/hook/js.js"],
  "ignoreDependencies": ["oxfmt", "oxlint"]
}
